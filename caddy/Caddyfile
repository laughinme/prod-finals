{$SITE_URL} {
    encode gzip zstd

    

    handle /api/* {
        reverse_proxy backend:8080
    }

    handle /connection/* {
        reverse_proxy centrifugo:8000
    }

    handle /ml/* {
        uri strip_prefix /ml
        reverse_proxy ml-service:8080
    }

    @ml_docs path /docs /docs/*
    handle @ml_docs {
        reverse_proxy ml-service:8080
    }

    @ml_redoc path /redoc /redoc/*
    handle @ml_redoc {
        reverse_proxy ml-service:8080
    }

    @qdrant_root path /qdrant
    redir @qdrant_root /qdrant/dashboard 308

    handle_path /qdrant/* {
        reverse_proxy qdrant:6333 {
            # Keep Qdrant dashboard redirects under /qdrant prefix.
            header_down Location ^/(.*)$ /qdrant/$1
        }
    }
    handle /openapi.json {
        reverse_proxy ml-service:8080
    }

    handle /media-public/* {
        reverse_proxy minio:9000
    }

    handle /media-private/* {
        reverse_proxy minio:9000
    }


    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
