# Compose project name
COMPOSE_PROJECT_NAME=monolith-template

# Public app URL (for links and storage public URL)
SITE_URL=http://localhost
STORAGE_ENDPOINT_PUBLIC=http://localhost

# Cookie policy for local/demo
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Demo admin credentials (used by demo seeder)
DEMO_ADMIN_EMAIL=admin@demo.local
DEMO_ADMIN_PASSWORD=Admin12345!
DEMO_ADMIN_USERNAME=Demo Admin

# Optional notifications
NOTIFICATIONS_PROVIDER=noop
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
