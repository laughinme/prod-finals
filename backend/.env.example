APP_STAGE=dev
DEBUG=true
FEED_TEST_MATCH_ENABLED=false

API_PORT=8080
API_HOST=0.0.0.0

SITE_URL=https://app.example.com
MAX_PHOTO_SIZE=5

# Internal ML service (backend -> ml-service)
ML_SERVICE_URL=http://localhost:8081
ML_SERVICE_TOKEN=dev-ml-token
# Optional: category preview text generation via HuggingFace Inference API.
ML_PREVIEW_LLM_ENABLED=false
ML_PREVIEW_LLM_PROVIDER=huggingface
ML_PREVIEW_LLM_API_KEY=
ML_PREVIEW_LLM_MODEL=google/flan-t5-small
ML_PREVIEW_LLM_TIMEOUT_SEC=4.0

# Object storage (MinIO / S3-compatible)
STORAGE_ENDPOINT_INTERNAL=http://minio:9000
STORAGE_ENDPOINT_PUBLIC=http://localhost
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_BUCKET=media-public
STORAGE_PRIVATE_BUCKET=media-private
STORAGE_PRESIGN_EXPIRES_SEC=600
STORAGE_USE_PATH_STYLE=true
STORAGE_AUTO_CREATE_BUCKETS=true

DATABASE_URL=postgresql+asyncpg://postgres:secret@localhost:5432/templatepg
REDIS_URL=redis://localhost:6379/0

CSRF_HMAC_KEY=change-me

# Shared secret for HS256/HS384/HS512 JWT signing
JWT_SECRET=change-me-change-me-change-me-1234
JWT_ALGO=HS256

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/

# Optional: enable only if calling backend directly without proxy
CORS_ALLOW_ORIGINS=http://localhost:5173,https://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=

# Optional notifications
NOTIFICATIONS_PROVIDER=noop
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Demo seed defaults
DEMO_ADMIN_EMAIL=admin@demo.local
DEMO_ADMIN_PASSWORD=Admin12345!
DEMO_ADMIN_USERNAME=Demo Admin
