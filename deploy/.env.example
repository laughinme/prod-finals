COMPOSE_PROJECT_NAME=chupapis
HTTP_PORT=80
HTTPS_PORT=443

APP_STAGE=prod
DEBUG=false
LOG_LEVEL=INFO
FEED_TEST_MATCH_ENABLED=false
SCHEDULER_ENABLED=false
FORWARDED_ALLOW_IPS=*

# Internal ML service (backend -> ml-service)
ML_SERVICE_URL=http://ml-service:8080
ML_SERVICE_TOKEN=change-me-ml-token
# Optional: category preview text generation via HuggingFace Inference API.
ML_PREVIEW_LLM_ENABLED=false
ML_PREVIEW_LLM_PROVIDER=huggingface
ML_PREVIEW_LLM_API_KEY=
ML_PREVIEW_LLM_MODEL=google/flan-t5-small
ML_PREVIEW_LLM_TIMEOUT_SEC=4.0
ML_SAMPLE_USER_COUNT=120
ML_SAMPLE_TX_PER_USER=20
ML_SAMPLE_SEED=42
ML_FEATURES_VERSION=features_v1
ML_MODEL_ARTIFACT_PATH=/app/ml/artifacts/model.json
ML_TRAIN_ON_START=false
ML_TRAIN_REQUIRED=false
ML_TRAIN_DATA_URL=
ML_TRAIN_DATA_PATH=/app/ml/data/train.csv
# Optional: file path inside ZIP archive (if dataset URL points to .zip).
ML_TRAIN_ARCHIVE_MEMBER=
ML_TRAIN_DOWNLOAD_TIMEOUT_SEC=120

# Manual training upload target (S3/MinIO).
# If ML_MODEL_S3_* are empty, script falls back to STORAGE_* values below.
ML_MODEL_UPLOAD_REQUIRED=false
ML_MODEL_S3_ENDPOINT=
ML_MODEL_S3_REGION=
ML_MODEL_S3_ACCESS_KEY=
ML_MODEL_S3_SECRET_KEY=
ML_MODEL_S3_BUCKET=
ML_MODEL_S3_PREFIX=ml-models
ML_MODEL_S3_KEY=
ML_MODEL_S3_SECURE=
ML_MODEL_S3_FORCE_PATH_STYLE=true

# Keep Qdrant user_profiles aligned with Postgres users on each deploy.
ML_SYNC_ON_DEPLOY=true
ML_SYNC_DELETE_ORPHANS=true
ML_SYNC_UPSERT_EXISTING=false
ML_SYNC_DIRECT_UPSERT_FALLBACK=true
ML_SYNC_COLLECTION=user_profiles
ML_SYNC_BATCH_SIZE=200
# Optional: override internal Qdrant URL for sync command.
ML_SYNC_QDRANT_URL=
# Optional: comma-separated fallback categories for cold-start profile sync.
ML_SYNC_DEFAULT_CATEGORIES=grocery,cafe,transport,travel,health

SITE_URL=https://app.example.com
# Keep empty when frontend and backend share one nginx domain.
VITE_API_BASE_URL=
MAX_PHOTO_SIZE=5

# Use docker compose service names here, not localhost.
DATABASE_URL=postgresql+asyncpg://postgres:change-me@db:5432/chupapis
REDIS_URL=redis://redis:6379/0

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chupapis

STORAGE_ENDPOINT_INTERNAL=http://minio:9000
STORAGE_ENDPOINT_PUBLIC=https://app.example.com
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=change-me
STORAGE_SECRET_KEY=change-me
STORAGE_PUBLIC_BUCKET=media-public
STORAGE_PRIVATE_BUCKET=media-private
STORAGE_PRESIGN_EXPIRES_SEC=600
STORAGE_USE_PATH_STYLE=true
STORAGE_AUTO_CREATE_BUCKETS=true

JWT_SECRET=prod-jwt-secret-change-me-please-1234
JWT_ALGO=HS256
CSRF_HMAC_KEY=prod-csrf-hmac-change-me-please-1234

COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/

CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=

NOTIFICATIONS_PROVIDER=noop
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

CENTRIFUGO_ENABLED=true
CENTRIFUGO_API_URL=http://centrifugo:8000/api/publish
# Optional. If empty, backend derives wss://<SITE_URL>/connection/websocket automatically.
CENTRIFUGO_WS_URL=
CENTRIFUGO_ALLOWED_ORIGINS=https://app.example.com
CENTRIFUGO_API_KEY=change-me-centrifugo-api-key
CENTRIFUGO_TOKEN_HMAC_SECRET=change-me-centrifugo-token-secret
CENTRIFUGO_TOKEN_TTL_SEC=900

DEMO_ADMIN_EMAIL=admin@demo.local
DEMO_ADMIN_PASSWORD=Admin12345!
DEMO_ADMIN_USERNAME=Demo Admin
